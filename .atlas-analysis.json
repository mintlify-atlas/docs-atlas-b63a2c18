  "keyFeatures": [
    "60–95% token reduction on tool outputs, logs, RAG chunks, files, and conversation history",
    "Library mode: compress(messages) in Python or TypeScript with zero infrastructure",
    "Proxy mode: zero-code-change HTTP proxy for any LLM client",
    "Agent wrap: one-command integration with Claude Code, Codex, Cursor, Aider, Cline, and more",
    "MCP server: headroom_compress, headroom_retrieve, headroom_stats tools for any MCP host",
    "CCR (Compress-Cache-Retrieve): fully reversible compression — originals retrievable on demand",
    "ContentRouter: auto-detects content type (JSON, code, logs, text, images) and applies best compressor",
    "SmartCrusher: statistical JSON array compression with anomaly preservation",
    "CodeCompressor: AST-aware compression for Python, JS/TS, Go, Rust, Java, C/C++",
    "Kompress-v2-base: HuggingFace model trained on agentic traces for prose compression",
    "CacheAligner: stabilizes prefixes to maximize provider KV cache hit rates",
    "Cross-agent shared memory: persistent, hierarchical memory across Claude, Codex, Gemini",
    "headroom learn: mines failed sessions and writes project-level corrections to CLAUDE.md",
    "Output token reduction: verbosity steering and effort routing cut model write-back cost",
    "Local-first: data never leaves your machine"
  ],
  "publicApiSurface": [
    "compress(messages, model, config) -> CompressResult",
    "compress_spreadsheet(...) -> CompressResult",
    "HeadroomClient(original_client, provider, default_mode, ...)",
    "HeadroomClient.chat.completions.create(...)",
    "HeadroomClient.chat.completions.simulate(...)",
    "HeadroomClient.get_stats() -> dict",
    "HeadroomClient.validate_setup() -> dict",
    "with_memory(client, user_id) -> wrapped client",
    "Memory(backend) — async .save() / .search()",
    "SharedContext.put() / .get()",
    "SmartCrusher, CacheAligner, TransformPipeline",
    "withHeadroom(new OpenAI()) — TypeScript SDK wrapper",
    "withHeadroom(new Anthropic()) — TypeScript SDK wrapper",
    "headroomMiddleware() — Vercel AI SDK middleware",
    "HeadroomChatModel(your_llm) — LangChain wrapper",
    "HeadroomAgnoModel(your_model) — Agno wrapper",
    "HeadroomCallback() — LiteLLM callback",
    "CompressionMiddleware — ASGI middleware",
    "headroom proxy [--port] [--mode] [--backend] [...]",
    "headroom wrap claude|codex|cursor|aider|copilot|cline|continue|goose|openhands|opencode|openclaw|vibe",
    "headroom unwrap <tool>",
    "headroom mcp install / serve",
    "headroom learn [--apply] [--target] [--verbosity]",
    "headroom doctor",
    "headroom perf",
    "headroom dashboard",
    "headroom savings",
    "headroom output-savings",
    "headroom update",
    "headroom init / install apply",
    "headroom copilot-auth login",
    "MCP tool: headroom_compress(content) -> compressed + hash",
    "MCP tool: headroom_retrieve(hash) -> original content",
    "MCP tool: headroom_stats() -> session statistics"
  ]
